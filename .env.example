# Central de Monitoramento TI - Variáveis de Ambiente
# 
# Copie este arquivo para .env e preencha com as URLs reais dos seus sistemas
# Exemplo: cp .env.example .env

# URLs dos Sistemas de Monitoramento
VITE_ZABBIX_URL=https://seu-zabbix.com.br
VITE_VISIDATA_URL=https://seu-visidata.com.br
VITE_CEC_URL=https://seu-cec.com.br
VITE_QLIK_URL=https://seu-qlik.com.br
VITE_DB_MONITOR_URL=https://seu-db-monitor.com.br
VITE_SECURITY_URL=https://seu-security.com.br
VITE_NETWORK_URL=https://seu-network.com.br
VITE_CONFIG_URL=https://seu-config.com.br

# Observações:
# - Todas as variáveis devem começar com VITE_ para serem acessíveis no frontend
# - Após alterar as URLs, reinicie o servidor de desenvolvimento (npm run dev)
# - Nunca commite o arquivo .env no Git (ele já está no .gitignore)
